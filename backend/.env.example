# Smart Document Management System - Environment Variables
# Copy this file to .env and update the values.
# Generate SECRET_KEY with: python -c "import secrets; print(secrets.token_urlsafe(64))"

# ============================================================
# REQUIRED (app will not start without these)
# ============================================================
SECRET_KEY=
DATABASE_URL=postgresql://postgres:your-password-here@localhost:5432/smart_docs
# Supabase example (use connection pooler in Transaction mode):
# DATABASE_URL=postgresql://postgres.your-project-ref:your-password@aws-0-ap-south-1.pooler.supabase.com:6543/postgres

# ============================================================
# Application
# ============================================================
APP_NAME=Smart Document Management System
APP_VERSION=1.0.0
DEBUG=false

# ============================================================
# JWT Authentication
# ============================================================
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================================
# CORS
# ============================================================
# JSON array of allowed origins. In production, use your actual domain.
# Wildcards ("*") are rejected by the config validator.
ALLOWED_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# ============================================================
# Redis & Celery
# ============================================================
# REDIS_PASSWORD is used in docker-compose to protect Redis.
# Update the URLs below if you change it.
REDIS_PASSWORD=smartdocs_redis_secret
REDIS_URL=redis://:smartdocs_redis_secret@localhost:6379/0
CELERY_BROKER_URL=redis://:smartdocs_redis_secret@localhost:6379/0
CELERY_RESULT_BACKEND=redis://:smartdocs_redis_secret@localhost:6379/0

# ============================================================
# Database (for local docker-compose Postgres, if used)
# ============================================================
POSTGRES_DB=smart_docs
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-strong-postgres-password

# ============================================================
# File Storage (local)
# ============================================================
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50

# ============================================================
# AWS S3 Storage (optional - set USE_S3=true to enable)
# ============================================================
USE_S3=false
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
S3_BUCKET_NAME=smart-docs-bucket

# ============================================================
# LLM Smart Extraction
# ============================================================
# Provider: "gemini", "ollama" (free local), "anthropic", "openai", or "local" (regex fallback)
LLM_PROVIDER=local
# Model name override (leave empty to use provider default):
#   gemini  -> gemini-2.0-flash
#   ollama  -> llama3.2
#   anthropic -> claude-sonnet-4-20250514
#   openai  -> gpt-4o-mini
LLM_MODEL=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
LLM_TIMEOUT_SECONDS=60

# ============================================================
# OAuth (optional - leave empty to disable)
# ============================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# ============================================================
# Rate Limiting
# ============================================================
RATE_LIMIT_AUTH=5/minute
RATE_LIMIT_UPLOAD=10/minute
RATE_LIMIT_DEFAULT=60/minute

# ============================================================
# Logging
# ============================================================
LOG_LEVEL=INFO
LOG_JSON_FORMAT=false

# ============================================================
# ML Model / OCR
# ============================================================
MODEL_DIR=./models
ML_CONFIDENCE_THRESHOLD=0.3
# Leave empty for default system Tesseract path
TESSERACT_CMD=
