# Smart Document Management System - Environment Variables
# Copy this file to .env and update the values

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/smart_docs

# JWT Authentication
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# File Storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50

# AWS S3 (set USE_S3=true to enable cloud storage)
USE_S3=false
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
S3_BUCKET_NAME=smart-docs-bucket

# Redis & Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ML Model
MODEL_DIR=./models
ML_CONFIDENCE_THRESHOLD=0.3

# Tesseract OCR (leave empty for default system path)
TESSERACT_CMD=
